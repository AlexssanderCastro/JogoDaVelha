<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background_with_pattern"
    tools:context=".MainActivity">

    <LinearLayout
        android:id="@+id/mainContainer"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="24dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Status Box -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/scoreboard_container"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/tvStatus"
                android:text="@string/status_initial"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFD700"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Game Board Section -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:background="@drawable/game_board_container"
            android:padding="20dp"
            android:layout_marginBottom="24dp">

            <GridLayout
                android:id="@+id/gridLayout"
                android:rowCount="3"
                android:columnCount="3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center">

                <!-- 9 Botões -->
                <androidx.appcompat.widget.AppCompatButton android:id="@+id/b0" style="@style/cell"/>
                <androidx.appcompat.widget.AppCompatButton android:id="@+id/b1" style="@style/cell"/>
                <androidx.appcompat.widget.AppCompatButton android:id="@+id/b2" style="@style/cell"/>

                <androidx.appcompat.widget.AppCompatButton android:id="@+id/b3" style="@style/cell"/>
                <androidx.appcompat.widget.AppCompatButton android:id="@+id/b4" style="@style/cell"/>
                <androidx.appcompat.widget.AppCompatButton android:id="@+id/b5" style="@style/cell"/>

                <androidx.appcompat.widget.AppCompatButton android:id="@+id/b6" style="@style/cell"/>
                <androidx.appcompat.widget.AppCompatButton android:id="@+id/b7" style="@style/cell"/>
                <androidx.appcompat.widget.AppCompatButton android:id="@+id/b8" style="@style/cell"/>

            </GridLayout>
        </FrameLayout>

        <!-- Scoreboard Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/scoreboard_container"
            android:padding="16dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp">

            <!-- Placar com 3 Cards -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:spacing="12dp"
                android:baselineAligned="false">

                <!-- Card Jogador X -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/player_x_card"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/score_label_x"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="#FF00FF"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:id="@+id/tvScoreX"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/score_initial"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:textColor="#FFD700"/>

                </LinearLayout>

                <!-- Card Jogador O -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/player_o_background"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/score_label_o"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="#0066CC"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:id="@+id/tvScoreO"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/score_initial"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:textColor="#FFD700"/>

                </LinearLayout>

                <!-- Card Empates -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/draw_background"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/score_label_draw"
                        android:textSize="24sp"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:id="@+id/tvScoreDraw"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/score_initial"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:textColor="#FFD700"/>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- Reset Button -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnReset"
            android:text="@string/btn_reset"
            android:textColor="#FFD700"
            android:textStyle="bold"
            android:background="@drawable/btn_reset_background"
            app:backgroundTint="@null"
            android:padding="16dp"
            android:layout_marginTop="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>